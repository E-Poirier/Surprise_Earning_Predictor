# Copy this file to ".env" in the project root (one command, nothing after it):
#   cp .env.example .env
# Then edit .env and paste your secrets. Never commit .env (it is gitignored).

# --- External services (two vendors) ---

# Finnhub — https://finnhub.io — earnings, estimates, news
FINNHUB_API_KEY=

# Hugging Face — https://huggingface.co/settings/tokens — FinBERT via Inference Providers
HF_API_KEY=

# --- Your app (not a third vendor) ---

# Any long random string YOU invent. Browsers/clients send it as header "x-api-key"
# so only your frontend (or you with curl) can call your FastAPI backend once we add auth.
API_KEY=

# Vite frontend (Phase 6): must match API_KEY — exposed to the browser for dev only.
# Vite loads this from the project root when you run `npm run dev` in frontend/.
VITE_API_KEY=
